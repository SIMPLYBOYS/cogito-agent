# 复制本文件为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会提交）
#   cp .env.example .env

# Anthropic 官方 API 金钥，从 https://console.anthropic.com 取得
ANTHROPIC_API_KEY=

# Slack Bot Token（xoxb- 开头），App 后台 OAuth & Permissions 页取得
# 所需 Bot Token Scopes: chat:write, app_mentions:read, im:history
SLACK_BOT_TOKEN=

# Slack Signing Secret，App 后台 Basic Information 页取得，用于校验回调签名
SLACK_SIGNING_SECRET=
