# 複製本文件為 .env 並填入真實值（.env 已被 .gitignore 忽略，不會提交）
#   cp .env.example .env
# cmd 入口會先 godotenv.Load() 載入本檔，再讀環境變數。

# ── LLM Provider ────────────────────────────────────────────────
# 預設 Claude。要換 OpenAI 相容端點（vLLM/Ollama/OpenRouter…）設 COGITO_PROVIDER=openai。
ANTHROPIC_API_KEY=                       # https://console.anthropic.com
# CLAUDE_MODEL=claude-opus-4-8           # 可選，預設 claude-opus-4-8

# COGITO_PROVIDER=openai                 # 切到 OpenAI 相容
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1   # 或 http://localhost:8000/v1（vLLM/Ollama）
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_CONTEXT_TOKENS=128000

# ── Slack（cmd/claw 服務端必填；走 Socket Mode，免公開 URL/ngrok）──────────
# Bot Token Scopes: chat:write, app_mentions:read, im:history
# 先在 App 後臺 Settings → Socket Mode 啟用，產生 App-Level Token（scope connections:write）。
SLACK_BOT_TOKEN=                         # xoxb- 開頭，App 後臺 OAuth & Permissions
SLACK_APP_TOKEN=                         # xapp- 開頭，App 後臺 Socket Mode（App-Level Token）

# ── Telegram（可選，多平台）：設了就與 Slack 同進程一起跑（getUpdates 長輪詢，免公開 URL）──
# 找 @BotFather /newbot 取 token。會話/工作目錄靠 platform 前綴與 Slack 天然隔離。
# TELEGRAM_BOT_TOKEN=                     # 123456:ABC-DEF... 開頭

# ── 鏈路追蹤 OTel（可選；設了 ENDPOINT 才上報，否則 no-op）────────
# Langfuse：ENDPOINT 用【基址】.../api/public/otel（SDK 會自己接 /v1/traces）。
# 注意 region：EU=cloud / US=us.cloud / JP=jp.cloud .langfuse.com，key 綁 region，選錯會 401。
# 認證免手編 base64：設了 LANGFUSE_PUBLIC_KEY+LANGFUSE_SECRET_KEY 就自動組 Authorization header。
# OTEL_EXPORTER_OTLP_ENDPOINT=https://jp.cloud.langfuse.com/api/public/otel
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <僅在想覆蓋自動派生時才手設>
# OTEL_TRACES_EXPORTER=console           # 改印到 stdout（不接後端也能本地看 span）

# ── 授權（Slack/Telegram 服務端【務必設】；不設＝fail-closed 拒絕所有入站）──────────
# COGITO_ALLOWED_USERS：可驅動 agent 的使用者 id（逗號分隔）。不設時 bot 對所有人拒絕回應——
#   這是刻意的：bot 入口 + host 直跑 + 工具執行 = 未授權者可在宿主機 RCE。先設白名單再上線。
#   ID 來源：Telegram＝純數字 user id（私訊 bot 後看 log 的「拒絕未授權使用者 <id>」即是你的 id）；
#   Slack＝U 開頭（如 U0123ABC）。同時跑兩平台就把兩邊 id 都放進來。
# COGITO_ALLOWED_USERS=123456789,U0123ABC
# COGITO_ADMIN_USERS：可 approve/reject 高危操作者（逗號分隔）。不設＝回退為 ALLOWED_USERS。
#   要真正做到「發起者≠批准者」（防自我放行），把審批權限收斂到少數管理員 id。
# COGITO_ADMIN_USERS=123456789
# COGITO_USER_LINK：DM 跨平台連續性——宣告同一人在各平台的 user id（= 連接一組、逗號分隔多組）。
#   設了之後該用戶在 Telegram/Slack 私聊共用同一份 session（歷史/工作目錄/忙碌鎖），
#   回覆與審批通知送到最後說話的平台。僅 DM 生效，群組不合併。信任宣告：只由你顯式配置。
# COGITO_USER_LINK=123456789=U0123ABC

# ── 沙箱（可選；不設＝host 直跑。面向 bot 建議開，讓 bash 不在宿主機執行）──────────
# COGITO_SANDBOX=docker                  # bash 丟進 per-session 容器（斷網/限資源）
# COGITO_SANDBOX_IMAGE=cogito-sandbox:latest
# COGITO_SANDBOX_NETWORK=none

# ── 成本熔斷 fallback 估價（可選；接非 Claude 模型時建議設為實際單價）──────────
# 未在 PricingModel 登記的模型（OpenAI 相容端點等）用這裡的單價估算成本，好讓 MaxCostUSD 熔斷生效。
# 不設＝預設 opus 級 in $5 / out $25（偏高＝寧可提早熔斷也不超支）。單位：美元/百萬 token。
# COGITO_PRICE_INPUT_USD=0.5
# COGITO_PRICE_OUTPUT_USD=1.5

# ── 持久化 / 容錯 / MCP（可選）───────────────────────────────────
# COGITO_SESSION_DIR=./workspace/sessions   # 設了才落地磁碟、跨重啟續傳（斷點粒度＝回合）
# COGITO_AUTO_RESUME=1                       # 自動續跑：進程活著時暫時性中斷退避重試；進程被硬砍（OOM/kill）重啟後掃出未完成任務續跑（各上限 3 次，防迴圈）。跨重啟續跑需一併設 COGITO_SESSION_DIR
# COGITO_SUMMARY=off                         # 關閉對話式入口的滾動摘要（預設開；bench 走預設關）
# COGITO_MCP_CONFIG=./.mcp.json             # 掛外部 MCP 工具（cp .mcp.json.example .mcp.json）

# ── 知識圖譜 embedding 選種子（可選；不設＝recall 用關鍵字選種子）──────
# 設了 COGITO_EMBED_MODEL 才啟用語意選種子；端點走 OpenAI 相容 /embeddings（雲端或本地 Ollama/vLLM）。
# 之後 `go run ./cmd/ingest -embed` 建向量快取，recall 即改用 embedding 選種子。
# COGITO_EMBED_MODEL=text-embedding-3-small
# COGITO_EMBED_BASE_URL=https://api.openai.com/v1   # 留空則沿用 OPENAI_BASE_URL
# COGITO_EMBED_API_KEY=sk-...                        # 留空則沿用 OPENAI_API_KEY

# ── Tier 4 自我進化（可選；產物只進暫存區、需人工 review）────────
# COGITO_SKILL_SYNTH=1                    # 成功任務 → 提案技能 .claw/skills-proposed/
# COGITO_MEMORY_SYNTH=1                   # 成功→提案慣例 / 失敗→教訓 .claw/AGENTS.proposed.md
# COGITO_KG_SYNTH=1                       # 任務後抽 typed 關係 → 提案邊 .claw/kg/edges.proposed.jsonl（每次任務多一次 LLM 呼叫）
