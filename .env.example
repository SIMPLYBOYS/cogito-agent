# 複製本文件為 .env 並填入真實值（.env 已被 .gitignore 忽略，不會提交）
#   cp .env.example .env

# Anthropic 官方 API 金鑰，從 https://console.anthropic.com 取得
ANTHROPIC_API_KEY=

# Slack Bot Token（xoxb- 開頭），App 後臺 OAuth & Permissions 頁取得
# 所需 Bot Token Scopes: chat:write, app_mentions:read, im:history
SLACK_BOT_TOKEN=

# Slack Signing Secret，App 後臺 Basic Information 頁取得，用於校驗回調簽名
SLACK_SIGNING_SECRET=
