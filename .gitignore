# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
/bin/
/dist/

# go build 在倉庫根目錄留下的 cmd 入口編譯產物（應只用 go run 或 go build -o ）
/claw
/claw-cli
/claw-demo
/claw-demo-oom
/claw-demo-subagent
/claw-demo-observability
/claw-demo-trace
/bench

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.*

# Go workspace file
go.work
go.work.sum

# Dependency directory (rarely committed for modules)
/vendor/

# Environment / secrets
.env
.env.*
!.env.example

# MCP 設定可能含敏感 server 參數（如金鑰）；只追蹤範例
.mcp.json
!.mcp.json.example

# Agent 沙箱：workspace 是独立 git repo（含 AGENTS.md / .claw/skills 及 agent 运行产物），
# 由其自身版本控制，不纳入主仓库追踪
/workspace/

# Session 持久化產物（COGITO_SESSION_DIR）：含對話歷史，勿入庫
/sessions/

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# OS files
.DS_Store
Thumbs.db
